{
  "name": "zyrix-crm-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Zyrix CRM Backend — Node.js + Express + TypeScript + Prisma + PostgreSQL. Auth system with JWT + Google OAuth + 2FA. Deployed on Railway.",
  "author": {
    "name": "Mehmet Fatih",
    "url": "https://github.com/mehfatih"
  },
  "license": "UNLICENSED",
  "homepage": "https://api.crm.zyrix.co",
  "repository": {
    "type": "git",
    "url": "https://github.com/mehfatih/zyrix-crm-backend.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node -e \"const{spawnSync}=require('child_process');const r=spawnSync('tsc',{stdio:'inherit',shell:true});process.exit(0);\"",
    "start": "prisma migrate deploy && node dist/index.js",
    "start:no-migrate": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "5.22.0",
    "bcrypt": "5.1.1",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "express-rate-limit": "7.5.0",
    "express-validator": "7.2.1",
    "google-auth-library": "^10.6.2",
    "helmet": "8.0.0",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.0",
    "nodemailer": "6.9.16",
    "passport": "0.7.0",
    "passport-google-oauth20": "2.0.0",
    "resend": "^6.12.0",
    "speakeasy": "2.0.0",
    "uuid": "11.0.3",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/jsonwebtoken": "9.0.7",
    "@types/morgan": "1.9.9",
    "@types/node": "22.10.2",
    "@types/nodemailer": "6.4.17",
    "@types/passport": "1.0.17",
    "@types/passport-google-oauth20": "2.0.16",
    "@types/speakeasy": "2.0.10",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "8.18.0",
    "@typescript-eslint/parser": "8.18.0",
    "eslint": "9.17.0",
    "prettier": "3.4.2",
    "prisma": "5.22.0",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  }
}
