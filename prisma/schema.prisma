// ============================================================================
// ZYRIX CRM — Prisma Schema (Full CRM + Admin Panel)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// COMPANIES — Multi-tenant root
// ─────────────────────────────────────────────────────────────────────────
model Company {
  id            String    @id @default(uuid())
  name          String
  slug          String    @unique
  plan          String    @default("free")

  status        String    @default("active")
  trialEndsAt   DateTime?
  suspendedAt   DateTime?
  suspendReason String?
  deletedAt     DateTime?

  billingEmail String?
  country      String?
  industry     String?
  size         String?
  baseCurrency String?  // default currency for reports & quotes (USD/SAR/TRY/AED...)

  // Per-merchant feature gating. Owner/admin of the Zyrix platform
  // (not the merchant themselves) can toggle individual features on
  // or off for any company from the admin panel. Shape:
  //   { "quotes": true, "contracts": false, "loyalty": true, ... }
  // When a key is absent, the feature defaults to ENABLED — so new
  // features automatically turn on for existing merchants without
  // requiring a data migration each time we add one.
  enabledFeatures Json @default("{}")

  // Idle timeout in minutes — the merchant's CRM dashboard auto-logs
  // out after this many minutes of no user activity. Default 10.
  // 0 or null disables the auto-lock (for TV-dashboard use cases).
  // Range: 0..60 enforced by the admin UI.
  idleTimeoutMinutes Int? @default(10)

  // Onboarding wizard — null means the user still needs to complete it.
  // When the wizard calls POST /api/onboarding/complete, we set this
  // timestamp, which flips the dashboard banner off and stops the
  // /onboarding redirect.
  onboardingCompletedAt DateTime?
  // Per-step completion map for the 5-step onboarding wizard (P3).
  // Shape: { profile: bool, country: bool, firstCustomer: bool,
  //          invitedTeam: bool, firstDeal: bool }.
  // Missing keys are treated as false. Survives sign-out so the wizard
  // can resume where it left off.
  onboardingProgress Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  customers      Customer[]
  deals          Deal[]
  activities     Activity[]
  tasks          Task[]
  quotes         Quote[]
  loyaltyProgram LoyaltyProgram?
  loyaltyTxns    LoyaltyTransaction[]
  taxRates       TaxRate[]
  followupSettings FollowupSettings?
  commissionRules   CommissionRule[]
  commissionEntries CommissionEntry[]
  campaigns         Campaign[]
  contracts         Contract[]
  portalTokens      PortalToken[]
  chatMessages      ChatMessage[]
  exchangeRates     ExchangeRate[]
  emailTemplates    EmailTemplate[]
  customFields      CustomField[]
  ecommerceStores   EcommerceStore[]
  webhookSubscriptions WebhookSubscription[]
  webhookEvents        WebhookEvent[]
  tags           Tag[]
  whatsappChats  WhatsappChat[]
  subscriptions  Subscription[]
  payments       Payment[]
  planOverrides  PlanOverride[]
  supportTickets SupportTicket[]
  auditLogs      AuditLog[]
  roles          Role[]

  @@index([status])
  @@index([plan])
  @@map("companies")
}

// ─────────────────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────────────────
model User {
  id                       String    @id @default(uuid())
  companyId                String
  email                    String    @unique
  passwordHash             String?
  fullName                 String
  phone                    String?
  role                     String    @default("member")
  // Optional pointer to a custom Role (RBAC, P1). When null, the user's
  // effective permissions come from the built-in `role` string above.
  // When set, permissions on the linked Role override the built-in map.
  customRoleId             String?
  googleId                 String?   @unique
  emailVerified            Boolean   @default(false)
  twoFactorSecret          String?
  twoFactorEnabled         Boolean   @default(false)
  // Array of hashed single-use backup codes (bcrypt). When the user
  // loses their authenticator, they can use one of these to log in,
  // and the matching code is wiped from the array.
  twoFactorBackupCodes     String[]  @default([])
  emailVerificationToken   String?   @unique
  emailVerificationExpires DateTime?
  passwordResetToken       String?   @unique
  passwordResetExpires     DateTime?
  lastLoginAt              DateTime?

  // 'en' | 'ar' | 'tr' — set via the onboarding wizard or /settings/profile.
  // Null means 'infer from browser Accept-Language' (existing behavior).
  preferredLocale String?

  // Profile expansion (UX #7). avatarUrl stores either an HTTP URL or
  // a base64 data URL (data:image/png;base64,...) — we accept either
  // because Option A deployment stores the image inline; future S3
  // integration would swap in CDN URLs transparently.
  avatarUrl          String?
  website            String?
  timezone           String?   // IANA TZ identifier, e.g. 'Asia/Riyadh'
  billingEmail       String?
  // Notification preference toggles — shape:
  //   { email_daily_digest: true, push_new_deals: false, ... }
  // Missing keys default to enabled (matches feature-flag semantics).
  notificationPrefs  Json      @default("{}")

  status         String    @default("active")
  disabledAt     DateTime?
  disabledReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customRole      Role?           @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  refreshTokens   RefreshToken[]
  ownedCustomers  Customer[]      @relation("CustomerOwner")
  ownedDeals      Deal[]          @relation("DealOwner")
  activities      Activity[]
  auditLogs       AuditLog[]
  assignedTickets SupportTicket[] @relation("TicketAssignee")
  createdTickets  SupportTicket[] @relation("TicketCreator")
  assignedTasks   Task[]          @relation("TaskAssignee")
  createdTasks    Task[]          @relation("TaskCreator")
  createdQuotes   Quote[]         @relation("QuoteCreator")
  loyaltyTxns     LoyaltyTransaction[] @relation("LoyaltyTxnCreator")
  commissionEntries CommissionEntry[]
  createdCampaigns Campaign[] @relation("CampaignCreator")
  createdContracts Contract[] @relation("ContractCreator")
  sentMessages     ChatMessage[] @relation("ChatSender")
  receivedMessages ChatMessage[] @relation("ChatRecipient")
  createdEmailTemplates EmailTemplate[]

  @@index([email])
  @@index([googleId])
  @@index([companyId])
  @@index([role])
  @@index([customRoleId])
  @@index([status])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────
// REFRESH TOKENS
// ─────────────────────────────────────────────────────────────────────────
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────────────────────────────────
model Customer {
  id            String  @id @default(uuid())
  companyId     String
  ownerId       String?
  brandId       String?  // optional multi-brand tagging

  fullName      String
  email         String?
  phone         String?
  whatsappPhone String?
  companyName   String?
  position      String?

  country String?
  city    String?
  address String?

  source        String?
  externalId    String?
  status        String  @default("new")
  lifetimeValue Decimal @default(0) @db.Decimal(12, 2)
  notes         String?
  customFields  Json    @default("{}")

  aiExtracted   Json?
  lastContactAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner         User?          @relation("CustomerOwner", fields: [ownerId], references: [id])
  deals         Deal[]
  activities    Activity[]
  tasks         Task[]
  quotes        Quote[]
  loyaltyTxns   LoyaltyTransaction[]
  campaignRecipients CampaignRecipient[]
  contracts     Contract[]
  portalTokens  PortalToken[]
  tags          CustomerTag[]
  whatsappChats WhatsappChat[]

  @@index([companyId])
  @@index([ownerId])
  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([source])
  @@index([externalId])
  @@map("customers")
}

// ─────────────────────────────────────────────────────────────────────────
// DEALS
// ─────────────────────────────────────────────────────────────────────────
model Deal {
  id         String  @id @default(uuid())
  companyId  String
  customerId String
  ownerId    String?
  brandId    String?  // optional multi-brand tagging

  title             String
  value             Decimal   @default(0) @db.Decimal(12, 2)
  currency          String    @default("USD")
  stage             String    @default("lead")
  probability       Int       @default(0)
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?
  description       String?
  lostReason        String?
  customFields      Json      @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  owner      User?      @relation("DealOwner", fields: [ownerId], references: [id])
  activities Activity[]
  tasks      Task[]
  quotes     Quote[]
  commissions CommissionEntry[]
  contracts  Contract[]

  @@index([companyId])
  @@index([customerId])
  @@index([ownerId])
  @@index([stage])
  @@map("deals")
}

// ─────────────────────────────────────────────────────────────────────────
// ACTIVITIES
// ─────────────────────────────────────────────────────────────────────────
model Activity {
  id         String  @id @default(uuid())
  companyId  String
  userId     String
  customerId String?
  dealId     String?
  brandId    String?  // optional multi-brand tagging

  type        String
  title       String
  content     String?
  metadata    Json?
  completedAt DateTime?
  dueDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deal     Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([customerId])
  @@index([dealId])
  @@index([userId])
  @@index([type])
  @@map("activities")
}

// ─────────────────────────────────────────────────────────────────────────
// TASKS — dedicated task management (separate from Activities timeline)
// ─────────────────────────────────────────────────────────────────────────
model Task {
  id           String  @id @default(uuid())
  companyId    String
  createdById  String
  assignedToId String?
  customerId   String?
  dealId       String?

  title       String
  description String?
  status      String  @default("todo") // todo | in_progress | done | cancelled
  priority    String  @default("medium") // low | medium | high | urgent

  dueDate     DateTime?
  completedAt DateTime?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  User      @relation("TaskCreator", fields: [createdById], references: [id])
  assignedTo User?     @relation("TaskAssignee", fields: [assignedToId], references: [id])
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  deal       Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([customerId])
  @@index([dealId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@map("tasks")
}

// ─────────────────────────────────────────────────────────────────────────
// TAGS
// ─────────────────────────────────────────────────────────────────────────
model Tag {
  id        String   @id @default(uuid())
  companyId String
  name      String
  color     String   @default("#0891B2")
  createdAt DateTime @default(now())

  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customers CustomerTag[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("tags")
}

model CustomerTag {
  customerId String
  tagId      String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
  @@map("customer_tags")
}

// ─────────────────────────────────────────────────────────────────────────
// WHATSAPP CHATS
// ─────────────────────────────────────────────────────────────────────────
model WhatsappChat {
  id         String  @id @default(uuid())
  companyId  String
  customerId String?

  phoneNumber String
  messageText String
  direction   String
  messageId   String? @unique
  mediaUrl    String?
  aiProcessed Boolean @default(false)
  aiExtracted Json?

  timestamp DateTime @default(now())
  createdAt DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([customerId])
  @@index([phoneNumber])
  @@index([timestamp])
  @@map("whatsapp_chats")
}

// ============================================================================
// ADMIN PANEL MODELS
// ============================================================================

// ─────────────────────────────────────────────────────────────────────────
// PLANS
// ─────────────────────────────────────────────────────────────────────────
model Plan {
  id            String  @id @default(uuid())
  slug          String  @unique
  name          String
  nameAr        String
  nameTr        String
  description   String?
  descriptionAr String?
  descriptionTr String?

  priceMonthlyUsd Decimal @default(0) @db.Decimal(10, 2)
  priceYearlyUsd  Decimal @default(0) @db.Decimal(10, 2)
  priceMonthlyTry Decimal @default(0) @db.Decimal(10, 2)
  priceYearlyTry  Decimal @default(0) @db.Decimal(10, 2)
  priceMonthlySar Decimal @default(0) @db.Decimal(10, 2)
  priceYearlySar  Decimal @default(0) @db.Decimal(10, 2)

  maxUsers       Int @default(1)
  maxCustomers   Int @default(100)
  maxDeals       Int @default(100)
  maxStorageGb   Int @default(1)
  maxWhatsappMsg Int @default(100)
  maxAiTokens    Int @default(10000)

  features Json @default("[]")

  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)
  sortOrder  Int     @default(0)
  color      String  @default("#0891B2")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

// ─────────────────────────────────────────────────────────────────────────
// PLAN OVERRIDES
// ─────────────────────────────────────────────────────────────────────────
model PlanOverride {
  id          String    @id @default(uuid())
  companyId   String
  featureSlug String
  enabled     Boolean   @default(true)
  expiresAt   DateTime?
  reason      String?
  grantedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, featureSlug])
  @@index([companyId])
  @@index([featureSlug])
  @@map("plan_overrides")
}

// ─────────────────────────────────────────────────────────────────────────
// SUBSCRIPTIONS
// ─────────────────────────────────────────────────────────────────────────
model Subscription {
  id        String @id @default(uuid())
  companyId String
  planId    String

  status String @default("active")

  billingCycle String  @default("monthly")
  currency     String  @default("USD")
  amount       Decimal @db.Decimal(10, 2)

  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime
  cancelAt           DateTime?
  cancelledAt        DateTime?
  trialStart         DateTime?
  trialEnd           DateTime?

  gateway           String?
  gatewayCustomerId String?
  gatewaySubId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([companyId])
  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────────────────────────────────
model Payment {
  id             String  @id @default(uuid())
  companyId      String
  subscriptionId String?

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("USD")
  status   String  @default("pending")

  gateway          String
  gatewayPaymentId String?
  gatewayReference String?

  method    String?
  last4     String?
  cardBrand String?

  description   String?
  failureReason String?
  metadata      Json?

  paidAt     DateTime?
  refundedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([companyId])
  @@index([subscriptionId])
  @@index([status])
  @@index([gateway])
  @@index([gatewayPaymentId])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────────────────────────────────
model AuditLog {
  id        String  @id @default(uuid())
  userId    String?
  companyId String?

  action     String
  entityType String?
  entityId   String?

  // Granular diff — { fieldName: { before, after }, ... }. Produced by
  // diffObjects(); only fields that actually changed are recorded.
  changes  Json?
  // Arbitrary context — request params, feature flags, etc.
  metadata Json?

  // Whole-record snapshots for compliance exports. before/after hold the
  // full entity payload at each side of the mutation so a compliance
  // auditor can reconstruct state without replaying diffs.
  before Json?
  after  Json?

  ipAddress String?
  userAgent String?
  // Refresh-token id the action was authenticated with, when available.
  // Lets us tie a sequence of actions to a specific login session.
  sessionId String?

  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([sessionId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────
// ANNOUNCEMENTS
// ─────────────────────────────────────────────────────────────────────────
model Announcement {
  id String @id @default(uuid())

  title     String
  titleAr   String?
  titleTr   String?
  content   String
  contentAr String?
  contentTr String?

  type        String  @default("info")
  target      String  @default("all")
  targetValue String?

  startsAt DateTime  @default(now())
  endsAt   DateTime?
  isActive Boolean   @default(true)

  createdBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([target])
  @@map("announcements")
}

// ─────────────────────────────────────────────────────────────────────────
// SUPPORT TICKETS
// ─────────────────────────────────────────────────────────────────────────
model SupportTicket {
  id          String @id @default(uuid())
  companyId   String
  createdById String

  subject     String
  description String
  category    String @default("general")
  priority    String @default("medium")
  status      String @default("open")

  assignedToId String?

  resolvedAt DateTime?
  closedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  User    @relation("TicketCreator", fields: [createdById], references: [id])
  assignedTo User?   @relation("TicketAssignee", fields: [assignedToId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@map("support_tickets")
}

// ─────────────────────────────────────────────────────────────────────────
// QUOTES & PROPOSALS
// ─────────────────────────────────────────────────────────────────────────
model Quote {
  id          String @id @default(uuid())
  companyId   String
  customerId  String
  dealId      String?
  createdById String

  quoteNumber String
  title       String
  status      String @default("draft") // draft | sent | viewed | accepted | rejected | expired

  issuedAt   DateTime?
  validUntil DateTime?
  acceptedAt DateTime?
  rejectedAt DateTime?
  sentAt     DateTime?

  currency       String  @default("TRY")
  subtotal       Decimal @default(0) @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal @default(0) @db.Decimal(12, 2)
  total          Decimal @default(0) @db.Decimal(12, 2)

  notes String?
  terms String?

  publicToken String?   @unique
  viewedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deal      Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  createdBy User      @relation("QuoteCreator", fields: [createdById], references: [id])
  items     QuoteItem[]

  @@unique([companyId, quoteNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([dealId])
  @@index([status])
  @@index([createdById])
  @@index([validUntil])
  @@map("quotes")
}

model QuoteItem {
  id              String  @id @default(uuid())
  quoteId         String
  name            String
  description     String?
  quantity        Decimal @default(1) @db.Decimal(12, 3)
  unitPrice       Decimal @default(0) @db.Decimal(12, 2)
  discountPercent Decimal @default(0) @db.Decimal(5, 2)
  taxPercent      Decimal @default(0) @db.Decimal(5, 2)
  lineTotal       Decimal @default(0) @db.Decimal(12, 2)
  position        Int     @default(0)

  createdAt DateTime @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_items")
}

// ─────────────────────────────────────────────────────────────────────────
// CUSTOMER LOYALTY
// ─────────────────────────────────────────────────────────────────────────
model LoyaltyProgram {
  id        String @id @default(uuid())
  companyId String @unique

  name          String  @default("Loyalty Program")
  isActive      Boolean @default(true)
  pointsPerUnit Decimal @default(1) @db.Decimal(10, 4)
  currency      String  @default("TRY")
  minRedeem     Int     @default(0)
  redeemValue   Decimal @default(0.01) @db.Decimal(10, 4)

  tiers Json?
  rules Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]

  @@map("loyalty_programs")
}

model LoyaltyTransaction {
  id          String  @id @default(uuid())
  companyId   String
  customerId  String
  programId   String
  createdById String?

  points        Int
  type          String  @default("earn") // earn | redeem | adjust | expire
  reason        String?
  referenceType String?
  referenceId   String?

  createdAt DateTime @default(now())

  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer  Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  program   LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  createdBy User?          @relation("LoyaltyTxnCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([customerId])
  @@index([programId])
  @@index([type])
  @@index([createdAt])
  @@map("loyalty_transactions")
}

// ─────────────────────────────────────────────────────────────────────────
// TAX ENGINE
// ─────────────────────────────────────────────────────────────────────────
model TaxRate {
  id          String  @id @default(uuid())
  companyId   String

  name        String
  code        String?
  countryCode String?
  ratePercent Decimal @default(0) @db.Decimal(6, 3)
  isDefault   Boolean @default(false)
  isActive    Boolean @default(true)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([isActive])
  @@index([countryCode])
  @@map("tax_rates")
}

// ─────────────────────────────────────────────────────────────────────────
// SMART FOLLOW-UP SETTINGS
// ─────────────────────────────────────────────────────────────────────────
model FollowupSettings {
  id        String @id @default(uuid())
  companyId String @unique

  isEnabled       Boolean @default(true)
  warningDays     Int     @default(5)
  criticalDays    Int     @default(10)
  includeStatuses Json?
  excludeInactive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("followup_settings")
}

// ─────────────────────────────────────────────────────────────────────────
// COMMISSION ENGINE
// ─────────────────────────────────────────────────────────────────────────
model CommissionRule {
  id          String  @id @default(uuid())
  companyId   String

  name        String
  description String?
  type        String  @default("percent") // flat | percent | tiered
  config      Json    // { rate } for percent, { amount } for flat, { tiers: [{ from, to?, rate }] } for tiered
  appliesTo   String  @default("all") // all | deal_stage | min_value
  appliesToValue String?

  isActive Boolean @default(true)
  priority Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entries CommissionEntry[]

  @@index([companyId])
  @@index([isActive])
  @@index([priority])
  @@map("commission_rules")
}

model CommissionEntry {
  id        String @id @default(uuid())
  companyId String
  ruleId    String
  userId    String
  dealId    String

  baseValue Decimal @default(0) @db.Decimal(12, 2)
  rate      Decimal @default(0) @db.Decimal(8, 4)
  amount    Decimal @default(0) @db.Decimal(12, 2)
  currency  String  @default("TRY")

  status     String    @default("pending") // pending | approved | paid | cancelled
  approvedAt DateTime?
  paidAt     DateTime?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rule    CommissionRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal    Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, ruleId, userId])
  @@index([companyId])
  @@index([userId])
  @@index([dealId])
  @@index([ruleId])
  @@index([status])
  @@map("commission_entries")
}

// ─────────────────────────────────────────────────────────────────────────
// MARKETING CAMPAIGNS
// ─────────────────────────────────────────────────────────────────────────
model Campaign {
  id          String @id @default(uuid())
  companyId   String
  createdById String

  name    String
  subject String?
  channel String @default("email")  // email | whatsapp | sms
  status  String @default("draft")  // draft | scheduled | sending | sent | failed | cancelled

  bodyHtml  String?
  bodyText  String?
  fromName  String?
  fromEmail String?
  replyTo   String?

  targetType  String  @default("all") // all | status | tag | manual
  targetValue String?

  scheduledAt DateTime?
  sentAt      DateTime?

  recipientCount Int @default(0)
  sentCount      Int @default(0)
  deliveredCount Int @default(0)
  openedCount    Int @default(0)
  clickedCount   Int @default(0)
  bouncedCount   Int @default(0)
  failedCount    Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  User                @relation("CampaignCreator", fields: [createdById], references: [id])
  recipients CampaignRecipient[]

  @@index([companyId])
  @@index([status])
  @@index([channel])
  @@index([scheduledAt])
  @@map("campaigns")
}

model CampaignRecipient {
  id         String @id @default(uuid())
  campaignId String
  customerId String

  email String?
  phone String?

  status       String    @default("queued") // queued | sent | delivered | opened | clicked | bounced | failed
  sentAt       DateTime?
  deliveredAt  DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  errorMessage String?

  messageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([campaignId, customerId])
  @@index([campaignId])
  @@index([customerId])
  @@index([status])
  @@map("campaign_recipients")
}

// ─────────────────────────────────────────────────────────────────────────
// CONTRACT MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────
model Contract {
  id             String  @id @default(uuid())
  companyId      String
  customerId     String
  dealId         String?
  createdById    String

  contractNumber String
  title          String
  description    String?
  status         String  @default("draft") // draft | pending_signature | signed | active | expired | terminated

  startDate   DateTime?
  endDate     DateTime?
  renewalDate DateTime?
  signedAt    DateTime?

  value    Decimal @default(0) @db.Decimal(12, 2)
  currency String  @default("TRY")

  fileUrl  String?
  fileName String?
  notes    String?
  terms    String?

  reminderSent Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  createdBy User     @relation("ContractCreator", fields: [createdById], references: [id])

  @@unique([companyId, contractNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([dealId])
  @@index([status])
  @@index([endDate])
  @@index([renewalDate])
  @@map("contracts")
}

// ─────────────────────────────────────────────────────────────────────────
// CUSTOMER PORTAL — Magic-link tokens
// ─────────────────────────────────────────────────────────────────────────
model PortalToken {
  id         String @id @default(uuid())
  customerId String
  companyId  String

  token     String   @unique
  purpose   String   @default("login") // login | session
  expiresAt DateTime
  usedAt    DateTime?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([companyId])
  @@index([expiresAt])
  @@map("portal_tokens")
}

// ─────────────────────────────────────────────────────────────────────────
// INTERNAL CHAT — Direct messages between users
// ─────────────────────────────────────────────────────────────────────────
model ChatMessage {
  id         String @id @default(uuid())
  companyId  String
  fromUserId String
  toUserId   String

  content String
  readAt  DateTime?

  createdAt DateTime @default(now())

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromUser User    @relation("ChatSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User    @relation("ChatRecipient", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([createdAt])
  @@index([readAt])
  @@map("chat_messages")
}

// ─────────────────────────────────────────────────────────────────────────
// EXCHANGE RATES — Multi-currency conversion
// ─────────────────────────────────────────────────────────────────────────
model ExchangeRate {
  id        String @id @default(uuid())
  companyId String

  fromCurrency String
  toCurrency   String
  rate         Decimal @db.Decimal(14, 6)

  effectiveAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, fromCurrency, toCurrency])
  @@index([companyId])
  @@index([fromCurrency])
  @@index([toCurrency])
  @@map("exchange_rates")
}

// ─────────────────────────────────────────────────────────────────────────
// EMAIL TEMPLATES — reusable templates for campaigns
// ─────────────────────────────────────────────────────────────────────────
model EmailTemplate {
  id          String  @id @default(uuid())
  companyId   String
  createdById String

  name        String
  description String?
  category    String  @default("general")
  subject     String
  bodyHtml    String
  bodyText    String?

  variables   Json    @default("[]")
  isShared    Boolean @default(true)
  usageCount  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: NoAction)

  @@index([companyId])
  @@index([category])
  @@map("email_templates")
}

// ─────────────────────────────────────────────────────────────────────────
// CUSTOM FIELDS — company-defined fields for customers + deals
// ─────────────────────────────────────────────────────────────────────────
model CustomField {
  id           String  @id @default(uuid())
  companyId    String

  entityType   String
  fieldKey     String
  label        String
  fieldType    String  @default("text")
  options      Json?
  required     Boolean @default(false)
  defaultValue String?
  position     Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, entityType, fieldKey])
  @@index([companyId])
  @@index([entityType])
  @@map("custom_fields")
}

// ─────────────────────────────────────────────────────────────────────────
// ECOMMERCE STORE CONNECTIONS — generalized for 40+ platforms
// (Shopify, Salla, Zid, YouCan, Ticimax, ikas, Ideasoft, T-Soft, etc.)
// ─────────────────────────────────────────────────────────────────────────
model EcommerceStore {
  id          String  @id @default(uuid())
  companyId   String

  platform    String  @default("shopify")
  shopDomain  String
  accessToken String
  apiKey      String?
  apiSecret   String?
  region      String?
  currency    String?
  metadata    Json    @default("{}")

  isActive    Boolean @default(true)

  lastSyncAt              DateTime?
  syncStatus              String    @default("idle")
  syncError               String?
  totalCustomersImported  Int       @default(0)
  totalOrdersImported     Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, platform, shopDomain])
  @@index([companyId])
  @@index([platform])
  @@map("ecommerce_stores")
}

// ─────────────────────────────────────────────────────────────────────────
// WEBHOOKS — per-store inbound subscriptions + event log
// ─────────────────────────────────────────────────────────────────────────
model WebhookSubscription {
  id          String  @id @default(uuid())
  companyId   String
  storeId     String? // null = company-wide (rare); usually tied to an EcommerceStore
  platform    String  // shopify | salla | zid | woocommerce | youcan | ...
  topic       String  // customers/create, orders/updated, etc.
  secret      String  // HMAC signing secret; regenerable
  isActive    Boolean @default(true)

  // Operational stats
  lastReceivedAt DateTime?
  receivedCount  Int       @default(0)
  failedCount    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  events WebhookEvent[]

  @@unique([companyId, platform, storeId, topic])
  @@index([companyId])
  @@index([platform])
  @@index([storeId])
  @@map("webhook_subscriptions")
}

model WebhookEvent {
  id             String  @id @default(uuid())
  companyId      String
  subscriptionId String?
  platform       String
  topic          String
  externalId     String? // platform's event id (e.g. Shopify X-Shopify-Webhook-Id)

  // pending | processing | done | failed | skipped | dead_letter
  // failed       = last attempt errored, will retry at nextRetryAt
  // dead_letter  = exhausted retry budget, needs human intervention
  status    String @default("pending")
  attempts  Int    @default(0)
  lastError String?

  // When to make the next retry attempt. null for terminal states
  // (done/skipped/dead_letter) and in-flight events (pending/processing).
  nextRetryAt DateTime?

  payloadRaw  String  @db.Text         // raw body as received (for retries + forensics)
  payloadJson Json    @default("{}")

  // Verification telemetry
  signatureOk Boolean @default(true)
  receivedAt  DateTime @default(now())
  processedAt DateTime?

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription WebhookSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([platform, topic])
  @@index([status])
  @@index([receivedAt])
  @@index([status, nextRetryAt])
  @@map("webhook_events")
}

// ─────────────────────────────────────────────────────────────────────────
// DASHBOARD LAYOUTS — per-user customizable widget grids
// ─────────────────────────────────────────────────────────────────────────
// Each user picks which widgets to show on their home dashboard and in
// what order. The layout is a JSON array of { id, type, width, config }
// objects. Width is one of 'full' | 'half' | 'third' | 'quarter' so the
// grid snaps to standard column counts; no free-form pixel dragging
// needed to keep layouts coherent across screen sizes.
//
// One row per (userId, companyId) — users can't share layouts across
// companies they belong to, and company-level default layouts are
// represented by a sentinel userId='company_default' row that the
// service falls back to when a user has no personal layout yet.
model DashboardLayout {
  id        String @id @default(uuid())
  companyId String
  userId    String // "company_default" for org-wide default
  widgets   Json   @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, userId])
  @@index([companyId])
  @@map("dashboard_layouts")
}

// ─────────────────────────────────────────────────────────────────────────
// TEMPLATES — industry-specific onboarding packages
// ─────────────────────────────────────────────────────────────────────────
// A Template is a bundle of Zyrix data that gets applied to a merchant's
// workspace in one click: pipeline stage names, tags, email templates,
// quote/contract boilerplates, custom fields, optionally seed customers
// and deals for a guided demo. Templates are global (not company-scoped)
// and curated — authored by Anthropic/Zyrix team, not user-submitted in
// this first version. A TemplateApplication row records each apply for
// undo / idempotency / ops analytics.
model Template {
  id        String @id @default(uuid())
  slug      String @unique // "apparel-ksa", "restaurant-istanbul", etc.
  industry  String // "retail", "restaurants", "saas", "services"
  region    String // "KSA", "TR", "UAE", "GLOBAL"
  locale    String @default("en") // primary language of the seed content
  name      String
  nameAr    String?
  nameTr    String?
  tagline   String?
  taglineAr String?
  taglineTr String?
  description   String?
  descriptionAr String?
  descriptionTr String?
  icon      String  @default("🧩") // emoji for browse UI
  color     String  @default("#0891B2")
  isFeatured Boolean @default(false)
  isActive   Boolean @default(true)
  sortOrder  Int     @default(0)
  // The applicable content bundle — JSON because shape varies per
  // template type. Readers of applyTemplate() treat these keys as
  // optional; any subset can be present. Shape:
  //   {
  //     pipelineStages?: string[],
  //     tags?: string[],
  //     customerStatuses?: string[],
  //     dealSources?: string[],
  //     customFields?: Array<{entityType, name, slug, type, options?}>,
  //     emailTemplates?: Array<{subject, body, purpose}>,
  //     quoteTemplate?: {title, items, terms},
  //     seedCustomers?: Array<{fullName, email?, phone?, companyName?, tags?}>,
  //     seedDeals?: Array<{title, value, currency, stage, customerIdx}>
  //   }
  bundle     Json
  // Estimated time to go live after applying. Surfaced in UI to set
  // expectations ("15 min setup" vs "2 hour walkthrough").
  setupMinutes Int @default(15)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications TemplateApplication[]

  @@index([industry])
  @@index([region])
  @@index([isActive, isFeatured])
  @@map("templates")
}

model TemplateApplication {
  id         String  @id @default(uuid())
  templateId String
  companyId  String
  userId     String
  // What got created when this template was applied — stored so an
  // 'Undo' action can remove exactly those records and not accidentally
  // delete other data the user created after applying.
  createdRecords Json @default("{}")
  status     String  @default("completed") // 'completed' | 'failed' | 'reverted'
  errorMessage String?
  appliedAt  DateTime @default(now())

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([templateId])
  @@index([companyId, appliedAt])
  @@map("template_applications")
}

// ─────────────────────────────────────────────────────────────────────────
// WORKFLOW AUTOMATION — Zapier-style automations
// ─────────────────────────────────────────────────────────────────────────
// A Workflow is one trigger + an ordered chain of actions, optionally
// gated by conditions. When a trigger event fires, the engine creates a
// WorkflowExecution row, evaluates each step's conditions, runs each
// enabled action, and records the outcome. Executions are durable —
// they persist across restarts, retry transient failures, and dead-letter
// after too many attempts so ops can inspect what broke.
//
// Trigger + action specs live in JSON because their shape varies: a
// schedule trigger has cron strings, a stage-change trigger has a
// stageSlug + direction, an email action has a template id, etc.
// Strict typing happens in the service layer where zod schemas validate
// each type's expected fields.
model Workflow {
  id        String @id @default(uuid())
  companyId String
  createdById String

  name        String
  description String?
  // Overall on/off switch — triggers ignore disabled workflows entirely.
  isEnabled Boolean @default(true)

  // Trigger: one per workflow in this MVP. Shape:
  //   { type: "customer.created" | "deal.stage_changed" | "schedule.daily" | ...,
  //     config: { ...type-specific fields } }
  trigger Json

  // Ordered action chain. Each item:
  //   { id, type, config, stopOnError?, delaySeconds? }
  // Actions run sequentially; if one fails and stopOnError is true
  // (default), remaining actions in the chain are skipped.
  actions Json @default("[]")

  // Optional AND-filters evaluated against the trigger payload before
  // the action chain runs. Shape:
  //   [{ field: "deal.value", operator: "gte", value: 1000 }, ...]
  conditions Json @default("[]")

  // Lightweight stats, updated on each execution completion
  runCount        Int       @default(0)
  successCount    Int       @default(0)
  failureCount    Int       @default(0)
  lastRunAt       DateTime?
  lastSuccessAt   DateTime?
  lastFailureAt   DateTime?
  lastError       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  executions WorkflowExecution[]

  @@index([companyId])
  @@index([companyId, isEnabled])
  @@map("workflows")
}

// One row per run. Pending rows are claimed by the worker; on completion
// the row transitions to 'completed' / 'failed' with the outcome +
// action-by-action step log captured in stepResults.
model WorkflowExecution {
  id         String @id @default(uuid())
  workflowId String
  companyId  String

  // Context snapshot: the trigger event payload the workflow saw when
  // it was queued. Actions can reference fields from this via {{trigger.customer.email}}
  // or similar templating (interpolation is implemented service-side).
  triggerPayload Json

  status String @default("pending")
  // pending | running | completed | failed | skipped_conditions

  // Action-by-action log. Shape:
  //   [{ actionId, actionType, status: 'success'|'failed'|'skipped',
  //      startedAt, finishedAt, error?, output? }, ...]
  stepResults Json @default("[]")

  // Retry tracking — same pattern as WebhookEvent
  attempts   Int       @default(0)
  lastError  String?
  nextRetryAt DateTime?

  queuedAt    DateTime  @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([companyId])
  @@index([status])
  @@index([status, nextRetryAt])
  @@index([companyId, queuedAt])
  @@map("workflow_executions")
}

// ─────────────────────────────────────────────────────────────────────────
// PUBLIC API KEYS
// ─────────────────────────────────────────────────────────────────────────
// API keys for third-party integrations (Zapier, custom scripts, etc.).
// We NEVER store the raw key — only a bcrypt hash. The key is shown to
// the user exactly once at creation time. If they lose it they create a
// new one. The key prefix (first 8 chars) is stored in plaintext so we
// can identify keys in logs without reading the hash.
//
// Scope model is simple for v1: 'read' (GET only) or 'write' (full CRUD).
// Granular per-resource scopes can be layered later without schema change
// by migrating scopes from a single string to a JSON array.
model ApiKey {
  id          String @id @default(uuid())
  companyId   String
  createdById String

  // Human-readable label the user sets ("Zapier", "Production webhook", etc.)
  name String

  // First 8 chars of the key (zy_live_XXXXXXXX...) for display in list UI
  // and log correlation. Not secret — the full key is only in the hash.
  keyPrefix String

  // bcrypt hash of the full key string. Never logged, never returned.
  keyHash String

  // Permissions. For v1: 'read' | 'write'.
  scope String @default("write")

  // When revoked, authentication rejects the key with 401. Keep the row
  // so audit logs that reference this key still resolve to something.
  revokedAt DateTime?

  // Last-used tracking for the list UI — "last active 3 days ago" helps
  // users identify stale keys they can safely revoke.
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, revokedAt])
  @@index([keyPrefix])
  @@map("api_keys")
}

// ─────────────────────────────────────────────────────────────────────────
// AI AGENTS — conversation threads + message history
// ─────────────────────────────────────────────────────────────────────────
// Unified schema for all three agents (Sales Assistant, Content Writer,
// Meeting Notes). Each row is one ongoing thread between a user and one
// agent kind. Messages are stored in a separate table for efficient
// paging and so we can run analytics on token usage / popular queries.
//
// agentKind values: 'sales' | 'content' | 'meeting'
// Role values: 'user' | 'assistant' | 'tool' | 'system'
// Tool calls and function results are encoded in the content JSON so
// replay is deterministic.
model AiThread {
  id        String @id @default(uuid())
  companyId String
  userId    String
  agentKind String

  // Short auto-generated title derived from the first message (or the
  // user renames it). Keeps the thread list scannable.
  title String?

  // For Meeting Notes agent: optional link back to an Activity row
  // (the meeting) so one click opens the original context.
  relatedActivityId String?

  // Conversation can end — reopened threads reset this.
  archived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AiMessage[]

  @@index([companyId, userId, agentKind])
  @@index([companyId, updatedAt])
  @@map("ai_threads")
}

model AiMessage {
  id       String @id @default(uuid())
  threadId String

  // 'user' | 'assistant' | 'tool' | 'system'
  role String

  // Plain text body for display. For role='tool' this is a short summary
  // of the function call output; the full raw output is in toolPayload.
  content String

  // For role='assistant' when the model called a tool: { name, args }
  // For role='tool' when returning the result: { name, result }
  toolCall Json?

  // Token usage — we track prompt + completion per message so a
  // Thread.tokenTotal can be derived without re-calling Gemini.
  promptTokens     Int @default(0)
  completionTokens Int @default(0)

  createdAt DateTime @default(now())

  thread AiThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("ai_messages")
}

// ─────────────────────────────────────────────────────────────────────────
// OAUTH INSTALL STATES
// ─────────────────────────────────────────────────────────────────────────
// Transient rows that track pending OAuth install flows. When a merchant
// clicks 'Install Zyrix' on Salla/Shopify/etc., we:
//   1. Generate a random state nonce + record this row with the merchant's
//      companyId + userId + provider + returnUrl
//   2. Redirect to the provider's consent screen with ?state=<nonce>
//   3. On callback, we look up the row by state, verify expiry, exchange
//      the code for a token, then delete the row
// The 15-minute expiry prevents stale/replayed auth grants.
model OAuthState {
  id        String   @id @default(uuid())
  state     String   @unique
  provider  String   // 'salla' | 'shopify' | future: 'zid' | 'ikas' | etc.
  companyId String
  userId    String
  // Where to redirect the user after successful install. Defaults to
  // /integrations so they see the freshly-connected store. Validated
  // server-side — must be a relative path on the same origin.
  returnUrl String   @default("/integrations")
  // Provider-specific context captured at init time (e.g. shop domain
  // for Shopify where we need the merchant's myshopify.com domain in
  // the callback handler).
  metadata  Json     @default("{}")
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([state])
  @@index([expiresAt])
  @@map("oauth_states")
}

// ─────────────────────────────────────────────────────────────────────────
// WHITE-LABEL BRAND SETTINGS
// ─────────────────────────────────────────────────────────────────────────
// Per-company branding overrides. Used to customize the dashboard
// appearance (logo + colors + display name) for enterprise customers
// who want Zyrix-powered CRM to look like their own product. Tier
// gating happens server-side: FREE/STARTER can set display name +
// colors, PRO can add logo, ENTERPRISE can add custom domain.
//
// Optional 1:1 with Company — a row is only created when a merchant
// first sets any branding. If no row exists, the dashboard falls back
// to default Zyrix branding.
model BrandSettings {
  id        String @id @default(uuid())
  companyId String @unique

  // Display name that overrides the 'Zyrix' product name in the UI
  // chrome (sidebar header, browser tab, welcome emails).
  displayName String?

  // Public URL of the uploaded logo. Lives in the same storage as
  // other company uploads (Cloudinary, S3, etc.). Null = fall back
  // to the default Zyrix logo.
  logoUrl String?

  // Optional favicon URL. Smaller file, shown in browser tab.
  faviconUrl String?

  // Hex color strings (e.g. '#0891B2'). Applied as CSS variables so
  // the whole dashboard re-themes without code changes. Validated
  // server-side to be valid 6-hex format.
  primaryColor String?
  accentColor  String?

  // Custom outbound email sender. When set, transactional emails
  // (welcome, password reset, quote PDFs) send from this address
  // via whatever provider the customer configured in SMTP or Resend.
  // For SPF/DKIM validation, the domain must be verified separately.
  emailFromName    String?
  emailFromAddress String?

  // Custom CNAME domain — enterprise tier only. When set and verified,
  // requests to https://{customDomain} route to this company's dashboard.
  // customDomainVerifiedAt gates the "is this actually live" check.
  customDomain            String?  @unique
  customDomainVerifiedAt  DateTime?

  // A per-company token for the TXT record the customer adds to DNS
  // to prove ownership of the custom domain. Cycled on re-verification.
  customDomainVerificationToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([customDomain])
  @@map("brand_settings")
}

// ─────────────────────────────────────────────────────────────────────────
// TEAM COLLABORATION — notifications, comments, mentions
// ─────────────────────────────────────────────────────────────────────────
// Core model for team-aware CRM interactions. Three tables wired together:
//
// Notification — in-app + (future) email pings for the user. Shown in the
//   bell-icon tray. Marked read when the user views the detail they
//   reference.
//
// Comment — threaded discussion attached to a domain object (customer,
//   deal, activity). Supports @mentions via a separate Mention table
//   rather than parsing the body each read.
//
// Mention — normalized record of 'user X was @mentioned in comment Y'.
//   Makes 'show me everywhere I was mentioned' cheap and avoids repeated
//   body parsing. Each mention produces a Notification for the mentioned
//   user.
model Notification {
  id        String @id @default(uuid())
  companyId String
  userId    String // recipient

  // 'mention' | 'deal_assigned' | 'comment_reply' | 'task_due' | 'deal_won'
  // etc. Used for icon + grouping in the UI; the frontend's i18n layer
  // renders the actual strings.
  kind String

  // Short display label — pre-rendered by the service so the UI doesn't
  // need to know about every possible kind. For mentions this is
  // 'Sara mentioned you on Acme Corp'.
  title String

  // Optional secondary body — the snippet of the comment that contained
  // the mention, first 120 chars of the relevant text, etc.
  body String?

  // Link target the UI navigates to when the notification is clicked.
  // e.g. '/customers/abc123?comment=xyz'
  link String?

  // Entity this notification references — useful for dedup and
  // for 'show all notifications about deal X' style queries.
  entityType String?
  entityId   String?

  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([companyId, userId, readAt])
  @@index([companyId, userId, createdAt])
  @@map("notifications")
}

model Comment {
  id        String @id @default(uuid())
  companyId String
  authorId  String

  // Polymorphic attachment — one of ('customer' | 'deal' | 'activity').
  // We don't use DB-level FKs here because the Customer/Deal/Activity
  // tables all have different shapes and the polymorphism is natural
  // at the app layer.
  entityType String
  entityId   String

  body String

  // For threaded replies — null = top-level comment. Replies deeper than
  // two levels fold back to two-level UI (discord-style).
  parentId String?

  editedAt  DateTime?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mentions Mention[]

  @@index([companyId, entityType, entityId, createdAt])
  @@index([companyId, authorId])
  @@index([parentId])
  @@map("comments")
}

model Mention {
  id         String @id @default(uuid())
  companyId  String
  commentId  String
  mentionedUserId String
  createdAt  DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, mentionedUserId])
  @@index([companyId, mentionedUserId])
  @@map("mentions")
}

// ─────────────────────────────────────────────────────────────────────────
// SCHEDULED REPORTS
// ─────────────────────────────────────────────────────────────────────────
// User-defined recurring reports. At each scheduled tick the cron runs
// the report's queries + emails the result to the recipient list. Reports
// share the underlying metric catalog with the interactive pivot builder;
// only the delivery layer is different.
model ScheduledReport {
  id        String @id @default(uuid())
  companyId String
  createdById String

  // Human label ('Weekly Sales Digest', 'Q4 Revenue by Region')
  name String

  // 'daily' | 'weekly' | 'monthly'
  cadence String

  // 0-23 for daily/weekly — the hour (UTC) to fire
  hour Int @default(9)

  // 0-6 for weekly (0=Sunday) — which day
  dayOfWeek Int?

  // 1-28 for monthly — which day of month (capped at 28 to avoid
  // edge cases with 29-31)
  dayOfMonth Int?

  // The metric keys to include. These are resolved by the reports
  // service against its hardcoded metric catalog (e.g. 'revenue_by_month',
  // 'deal_conversion_rate', 'top_customers_by_ltv'). JSON array of
  // strings — keeps the schema flexible as we add metrics.
  metrics Json @default("[]")

  // Email recipients. Comma-separated or JSON array of email strings.
  // Each recipient must be a user in the same company to prevent
  // data leakage; service validates at runtime.
  recipients Json @default("[]")

  isEnabled Boolean @default(true)
  lastRunAt DateTime?
  lastError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, isEnabled])
  @@index([isEnabled, cadence])
  @@map("scheduled_reports")
}

// ─────────────────────────────────────────────────────────────────────────
// MULTI-BRAND MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────
// A merchant can run multiple brands under one Zyrix account. Each
// Customer/Deal/Activity/Quote/Contract can optionally be tagged with
// a brandId for cross-brand reporting + filtering. Rows without brandId
// are treated as 'unbranded' and visible in every brand's view.
//
// This is a FLAT hierarchy under Company (no brand-within-brand).
// Default brand behavior: when a user picks a current brand in the
// brand switcher, newly-created rows inherit that brandId automatically.
model Brand {
  id          String  @id @default(uuid())
  companyId   String
  name        String
  slug        String  // e.g. 'levana' — used in URLs + filters
  logoUrl     String?
  primaryColor String?  // hex like '#FF6B9D'
  description String?

  isDefault   Boolean @default(false)  // shown pre-selected in brand switcher
  isArchived  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, slug])
  @@index([companyId])
  @@index([companyId, isArchived])
  @@map("brands")
}

// ─────────────────────────────────────────────────────────────────────────
// TAX INVOICES — ZATCA (Saudi Arabia) + e-Fatura/e-Arşiv (Turkey)
// ─────────────────────────────────────────────────────────────────────────
// Country-specific electronic invoicing compliance. One model covers both
// regimes — the `regime` field discriminates which serializer/hash/submit
// pipeline runs. Design keeps all compliance data in one row so support
// staff can audit a single record when disputes arise.
model TaxInvoice {
  id        String @id @default(uuid())
  companyId String

  // Regime: 'zatca' (Saudi) | 'efatura' (Turkey B2B) | 'earsiv' (Turkey B2C)
  regime String

  // Type: 'standard' (regular tax invoice) | 'simplified' (retail <1000 SAR)
  // | 'credit_note' | 'debit_note'. Maps to ZATCA's InvoiceTypeCode.
  type String @default("standard")

  // Sequential invoice number — required to be gapless for ZATCA.
  // Service assigns these with row-level locking per-company.
  invoiceNumber String

  // Link to the originating business record. One of these will be set.
  quoteId    String?
  contractId String?
  dealId     String?

  // Party details snapshotted at issue time — MUST not change even if
  // the source record is edited. Regulators audit the invoice as it
  // was when issued.
  sellerName    String
  sellerVatNo   String?
  sellerAddress String?
  buyerName     String
  buyerVatNo    String?
  buyerAddress  String?

  // Monetary totals (Decimal for financial precision)
  currency       String   @default("SAR")
  subtotal       Decimal  @db.Decimal(15, 2)
  discountAmount Decimal  @default(0) @db.Decimal(15, 2)
  taxRate        Decimal  @default(0) @db.Decimal(5, 2)   // e.g. 15.00 for 15%
  taxAmount      Decimal  @db.Decimal(15, 2)
  totalAmount    Decimal  @db.Decimal(15, 2)

  // Line items as JSON so we don't need a separate table for a
  // read-mostly artifact. Shape: { description, quantity, unitPrice,
  // discount, taxRate, lineTotal }
  lineItems Json @default("[]")

  // Timestamp of issuance (frozen). ZATCA requires ISO 8601 with
  // timezone — we store UTC and render with TZ at serialization.
  issuedAt DateTime @default(now())

  // ──────────────────────────────────────────────────────────────
  // Compliance artifacts — populated by the regime-specific serializer
  // ──────────────────────────────────────────────────────────────

  // UBL 2.1 XML payload. Stored as text so we can re-serve it without
  // re-generating (required for disputes + provider re-submissions).
  xml String?

  // Base64-encoded QR code TLV payload (Saudi ZATCA Phase 1 + 2).
  // Printed on customer receipts so anyone can verify with the
  // government-issued scanner app.
  qrCode String?

  // SHA-256 hash of the XML — part of ZATCA's hash chain. Every
  // invoice's hash incorporates the previous invoice's hash
  // (previousInvoiceHash) to prevent mid-stream insertions.
  invoiceHash         String?
  previousInvoiceHash String?

  // Provider/government submission tracking
  status         String    @default("draft") // 'draft' | 'submitted' | 'approved' | 'rejected'
  externalId     String?   // provider-assigned ID (ZATCA cleared UUID, e.g.)
  submittedAt    DateTime?
  approvedAt     DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, regime, invoiceNumber])
  @@index([companyId, regime])
  @@index([companyId, status])
  @@index([companyId, issuedAt])
  @@map("tax_invoices")
}

// ─────────────────────────────────────────────────────────────────────────
// SESSION EVENTS — for idle timeout KPIs
// ─────────────────────────────────────────────────────────────────────────
// Each row = one "something happened to this session" event. The primary
// use case is letting managers see how often employees close Zyrix
// actively vs get logged out by idle timeout — a signal of engagement
// + potential training needs (frequent auto-logouts may indicate the
// employee is being interrupted a lot or using the system as a
// reference rather than a working tool).
//
// Why a separate table instead of piggybacking on AuditLog:
//   • Volume — dozens per user per day, vs AuditLog's business-level
//     events (deal created, contract signed) that are much rarer
//   • Query pattern — we aggregate by (userId, day, eventType) for
//     the KPI dashboard, which is different from AuditLog's "who did
//     what to entity X?" pattern
//   • Retention — can be rolled up/archived separately if volume
//     becomes an issue; business audit events need to be kept much
//     longer for compliance
// ─────────────────────────────────────────────────────────────────────────
// IP ALLOWLIST — P4
// ─────────────────────────────────────────────────────────────────────────
// Per-company CIDR blocks. When a company has ANY entry in this table,
// all authenticated requests must originate from an IP that falls in
// one of the ranges. Empty list = allow all (opt-in feature).
model IpAllowlist {
  id        String   @id @default(uuid())
  companyId String
  cidr      String   // e.g. "203.0.113.0/24" or "203.0.113.42/32"
  label     String   // e.g. "Office", "VPN", "Home"
  createdBy String
  createdAt DateTime @default(now())

  @@index([companyId])
  @@map("ip_allowlist")
}

model SessionEvent {
  id        String @id @default(uuid())
  userId    String
  companyId String

  // 'login'              — fresh signin (via password, OAuth, magic link)
  // 'manual_logout'      — user clicked the logout button
  // 'auto_logout_idle'   — idle timeout fired (10 min default)
  // 'session_expired'    — refresh token rejected / tokens cleared
  eventType String

  // Client-side metadata for debugging: user agent, locale, viewport.
  // JSON instead of columns so we can add/remove fields without migrations.
  metadata Json @default("{}")

  createdAt DateTime @default(now())

  @@index([companyId, userId, createdAt])
  @@index([companyId, eventType, createdAt])
  @@index([userId, createdAt])
  @@map("session_events")
}

// ─────────────────────────────────────────────────────────────────────────
// ROLES — Role-Based Access Control (P1)
// ─────────────────────────────────────────────────────────────────────────
// Per-company roles with a fine-grained permission array. The 4 built-in
// roles (owner/admin/manager/member) are seeded with isSystem=true and
// must not be edited/deleted via the public API — their permission sets
// live in code (src/constants/permissions.ts) and serve as the fallback
// when User.customRoleId is null. Custom roles created by merchants are
// isSystem=false and fully editable.
model Role {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  // String array of permission keys from the PERMISSIONS catalog, e.g.
  //   ["customers:read", "customers:write", "deals:read", ...]
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users   User[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("roles")
}
