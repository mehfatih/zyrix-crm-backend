// ============================================================================
// ZYRIX CRM — Prisma Schema (Full CRM + Admin Panel)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// COMPANIES — Multi-tenant root
// ─────────────────────────────────────────────────────────────────────────
model Company {
  id            String    @id @default(uuid())
  name          String
  slug          String    @unique
  plan          String    @default("free")

  status        String    @default("active")
  trialEndsAt   DateTime?
  suspendedAt   DateTime?
  suspendReason String?
  deletedAt     DateTime?

  billingEmail String?
  country      String?
  industry     String?
  size         String?
  baseCurrency String?  // default currency for reports & quotes (USD/SAR/TRY/AED...)

  // Onboarding wizard — null means the user still needs to complete it.
  // When the wizard calls POST /api/onboarding/complete, we set this
  // timestamp, which flips the dashboard banner off and stops the
  // /onboarding redirect.
  onboardingCompletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  customers      Customer[]
  deals          Deal[]
  activities     Activity[]
  tasks          Task[]
  quotes         Quote[]
  loyaltyProgram LoyaltyProgram?
  loyaltyTxns    LoyaltyTransaction[]
  taxRates       TaxRate[]
  followupSettings FollowupSettings?
  commissionRules   CommissionRule[]
  commissionEntries CommissionEntry[]
  campaigns         Campaign[]
  contracts         Contract[]
  portalTokens      PortalToken[]
  chatMessages      ChatMessage[]
  exchangeRates     ExchangeRate[]
  emailTemplates    EmailTemplate[]
  customFields      CustomField[]
  ecommerceStores   EcommerceStore[]
  webhookSubscriptions WebhookSubscription[]
  webhookEvents        WebhookEvent[]
  tags           Tag[]
  whatsappChats  WhatsappChat[]
  subscriptions  Subscription[]
  payments       Payment[]
  planOverrides  PlanOverride[]
  supportTickets SupportTicket[]
  auditLogs      AuditLog[]

  @@index([status])
  @@index([plan])
  @@map("companies")
}

// ─────────────────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────────────────
model User {
  id                       String    @id @default(uuid())
  companyId                String
  email                    String    @unique
  passwordHash             String?
  fullName                 String
  phone                    String?
  role                     String    @default("member")
  googleId                 String?   @unique
  emailVerified            Boolean   @default(false)
  twoFactorSecret          String?
  twoFactorEnabled         Boolean   @default(false)
  // Array of hashed single-use backup codes (bcrypt). When the user
  // loses their authenticator, they can use one of these to log in,
  // and the matching code is wiped from the array.
  twoFactorBackupCodes     String[]  @default([])
  emailVerificationToken   String?   @unique
  emailVerificationExpires DateTime?
  passwordResetToken       String?   @unique
  passwordResetExpires     DateTime?
  lastLoginAt              DateTime?

  // 'en' | 'ar' | 'tr' — set via the onboarding wizard or /settings/profile.
  // Null means 'infer from browser Accept-Language' (existing behavior).
  preferredLocale String?

  status         String    @default("active")
  disabledAt     DateTime?
  disabledReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  refreshTokens   RefreshToken[]
  ownedCustomers  Customer[]      @relation("CustomerOwner")
  ownedDeals      Deal[]          @relation("DealOwner")
  activities      Activity[]
  auditLogs       AuditLog[]
  assignedTickets SupportTicket[] @relation("TicketAssignee")
  createdTickets  SupportTicket[] @relation("TicketCreator")
  assignedTasks   Task[]          @relation("TaskAssignee")
  createdTasks    Task[]          @relation("TaskCreator")
  createdQuotes   Quote[]         @relation("QuoteCreator")
  loyaltyTxns     LoyaltyTransaction[] @relation("LoyaltyTxnCreator")
  commissionEntries CommissionEntry[]
  createdCampaigns Campaign[] @relation("CampaignCreator")
  createdContracts Contract[] @relation("ContractCreator")
  sentMessages     ChatMessage[] @relation("ChatSender")
  receivedMessages ChatMessage[] @relation("ChatRecipient")
  createdEmailTemplates EmailTemplate[]

  @@index([email])
  @@index([googleId])
  @@index([companyId])
  @@index([role])
  @@index([status])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────
// REFRESH TOKENS
// ─────────────────────────────────────────────────────────────────────────
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────────────────────────────────
model Customer {
  id            String  @id @default(uuid())
  companyId     String
  ownerId       String?

  fullName      String
  email         String?
  phone         String?
  whatsappPhone String?
  companyName   String?
  position      String?

  country String?
  city    String?
  address String?

  source        String?
  externalId    String?
  status        String  @default("new")
  lifetimeValue Decimal @default(0) @db.Decimal(12, 2)
  notes         String?
  customFields  Json    @default("{}")

  aiExtracted   Json?
  lastContactAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner         User?          @relation("CustomerOwner", fields: [ownerId], references: [id])
  deals         Deal[]
  activities    Activity[]
  tasks         Task[]
  quotes        Quote[]
  loyaltyTxns   LoyaltyTransaction[]
  campaignRecipients CampaignRecipient[]
  contracts     Contract[]
  portalTokens  PortalToken[]
  tags          CustomerTag[]
  whatsappChats WhatsappChat[]

  @@index([companyId])
  @@index([ownerId])
  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([source])
  @@index([externalId])
  @@map("customers")
}

// ─────────────────────────────────────────────────────────────────────────
// DEALS
// ─────────────────────────────────────────────────────────────────────────
model Deal {
  id         String  @id @default(uuid())
  companyId  String
  customerId String
  ownerId    String?

  title             String
  value             Decimal   @default(0) @db.Decimal(12, 2)
  currency          String    @default("USD")
  stage             String    @default("lead")
  probability       Int       @default(0)
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?
  description       String?
  lostReason        String?
  customFields      Json      @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  owner      User?      @relation("DealOwner", fields: [ownerId], references: [id])
  activities Activity[]
  tasks      Task[]
  quotes     Quote[]
  commissions CommissionEntry[]
  contracts  Contract[]

  @@index([companyId])
  @@index([customerId])
  @@index([ownerId])
  @@index([stage])
  @@map("deals")
}

// ─────────────────────────────────────────────────────────────────────────
// ACTIVITIES
// ─────────────────────────────────────────────────────────────────────────
model Activity {
  id         String  @id @default(uuid())
  companyId  String
  userId     String
  customerId String?
  dealId     String?

  type        String
  title       String
  content     String?
  metadata    Json?
  completedAt DateTime?
  dueDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deal     Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([customerId])
  @@index([dealId])
  @@index([userId])
  @@index([type])
  @@map("activities")
}

// ─────────────────────────────────────────────────────────────────────────
// TASKS — dedicated task management (separate from Activities timeline)
// ─────────────────────────────────────────────────────────────────────────
model Task {
  id           String  @id @default(uuid())
  companyId    String
  createdById  String
  assignedToId String?
  customerId   String?
  dealId       String?

  title       String
  description String?
  status      String  @default("todo") // todo | in_progress | done | cancelled
  priority    String  @default("medium") // low | medium | high | urgent

  dueDate     DateTime?
  completedAt DateTime?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  User      @relation("TaskCreator", fields: [createdById], references: [id])
  assignedTo User?     @relation("TaskAssignee", fields: [assignedToId], references: [id])
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  deal       Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([customerId])
  @@index([dealId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@map("tasks")
}

// ─────────────────────────────────────────────────────────────────────────
// TAGS
// ─────────────────────────────────────────────────────────────────────────
model Tag {
  id        String   @id @default(uuid())
  companyId String
  name      String
  color     String   @default("#0891B2")
  createdAt DateTime @default(now())

  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customers CustomerTag[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("tags")
}

model CustomerTag {
  customerId String
  tagId      String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
  @@map("customer_tags")
}

// ─────────────────────────────────────────────────────────────────────────
// WHATSAPP CHATS
// ─────────────────────────────────────────────────────────────────────────
model WhatsappChat {
  id         String  @id @default(uuid())
  companyId  String
  customerId String?

  phoneNumber String
  messageText String
  direction   String
  messageId   String? @unique
  mediaUrl    String?
  aiProcessed Boolean @default(false)
  aiExtracted Json?

  timestamp DateTime @default(now())
  createdAt DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([customerId])
  @@index([phoneNumber])
  @@index([timestamp])
  @@map("whatsapp_chats")
}

// ============================================================================
// ADMIN PANEL MODELS
// ============================================================================

// ─────────────────────────────────────────────────────────────────────────
// PLANS
// ─────────────────────────────────────────────────────────────────────────
model Plan {
  id            String  @id @default(uuid())
  slug          String  @unique
  name          String
  nameAr        String
  nameTr        String
  description   String?
  descriptionAr String?
  descriptionTr String?

  priceMonthlyUsd Decimal @default(0) @db.Decimal(10, 2)
  priceYearlyUsd  Decimal @default(0) @db.Decimal(10, 2)
  priceMonthlyTry Decimal @default(0) @db.Decimal(10, 2)
  priceYearlyTry  Decimal @default(0) @db.Decimal(10, 2)
  priceMonthlySar Decimal @default(0) @db.Decimal(10, 2)
  priceYearlySar  Decimal @default(0) @db.Decimal(10, 2)

  maxUsers       Int @default(1)
  maxCustomers   Int @default(100)
  maxDeals       Int @default(100)
  maxStorageGb   Int @default(1)
  maxWhatsappMsg Int @default(100)
  maxAiTokens    Int @default(10000)

  features Json @default("[]")

  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)
  sortOrder  Int     @default(0)
  color      String  @default("#0891B2")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

// ─────────────────────────────────────────────────────────────────────────
// PLAN OVERRIDES
// ─────────────────────────────────────────────────────────────────────────
model PlanOverride {
  id          String    @id @default(uuid())
  companyId   String
  featureSlug String
  enabled     Boolean   @default(true)
  expiresAt   DateTime?
  reason      String?
  grantedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, featureSlug])
  @@index([companyId])
  @@index([featureSlug])
  @@map("plan_overrides")
}

// ─────────────────────────────────────────────────────────────────────────
// SUBSCRIPTIONS
// ─────────────────────────────────────────────────────────────────────────
model Subscription {
  id        String @id @default(uuid())
  companyId String
  planId    String

  status String @default("active")

  billingCycle String  @default("monthly")
  currency     String  @default("USD")
  amount       Decimal @db.Decimal(10, 2)

  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime
  cancelAt           DateTime?
  cancelledAt        DateTime?
  trialStart         DateTime?
  trialEnd           DateTime?

  gateway           String?
  gatewayCustomerId String?
  gatewaySubId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([companyId])
  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────────────────────────────────
model Payment {
  id             String  @id @default(uuid())
  companyId      String
  subscriptionId String?

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("USD")
  status   String  @default("pending")

  gateway          String
  gatewayPaymentId String?
  gatewayReference String?

  method    String?
  last4     String?
  cardBrand String?

  description   String?
  failureReason String?
  metadata      Json?

  paidAt     DateTime?
  refundedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([companyId])
  @@index([subscriptionId])
  @@index([status])
  @@index([gateway])
  @@index([gatewayPaymentId])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────────────────────────────────
model AuditLog {
  id        String  @id @default(uuid())
  userId    String?
  companyId String?

  action     String
  entityType String?
  entityId   String?

  changes  Json?
  metadata Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────
// ANNOUNCEMENTS
// ─────────────────────────────────────────────────────────────────────────
model Announcement {
  id String @id @default(uuid())

  title     String
  titleAr   String?
  titleTr   String?
  content   String
  contentAr String?
  contentTr String?

  type        String  @default("info")
  target      String  @default("all")
  targetValue String?

  startsAt DateTime  @default(now())
  endsAt   DateTime?
  isActive Boolean   @default(true)

  createdBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([target])
  @@map("announcements")
}

// ─────────────────────────────────────────────────────────────────────────
// SUPPORT TICKETS
// ─────────────────────────────────────────────────────────────────────────
model SupportTicket {
  id          String @id @default(uuid())
  companyId   String
  createdById String

  subject     String
  description String
  category    String @default("general")
  priority    String @default("medium")
  status      String @default("open")

  assignedToId String?

  resolvedAt DateTime?
  closedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  User    @relation("TicketCreator", fields: [createdById], references: [id])
  assignedTo User?   @relation("TicketAssignee", fields: [assignedToId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@map("support_tickets")
}

// ─────────────────────────────────────────────────────────────────────────
// QUOTES & PROPOSALS
// ─────────────────────────────────────────────────────────────────────────
model Quote {
  id          String @id @default(uuid())
  companyId   String
  customerId  String
  dealId      String?
  createdById String

  quoteNumber String
  title       String
  status      String @default("draft") // draft | sent | viewed | accepted | rejected | expired

  issuedAt   DateTime?
  validUntil DateTime?
  acceptedAt DateTime?
  rejectedAt DateTime?
  sentAt     DateTime?

  currency       String  @default("TRY")
  subtotal       Decimal @default(0) @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal @default(0) @db.Decimal(12, 2)
  total          Decimal @default(0) @db.Decimal(12, 2)

  notes String?
  terms String?

  publicToken String?   @unique
  viewedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deal      Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  createdBy User      @relation("QuoteCreator", fields: [createdById], references: [id])
  items     QuoteItem[]

  @@unique([companyId, quoteNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([dealId])
  @@index([status])
  @@index([createdById])
  @@index([validUntil])
  @@map("quotes")
}

model QuoteItem {
  id              String  @id @default(uuid())
  quoteId         String
  name            String
  description     String?
  quantity        Decimal @default(1) @db.Decimal(12, 3)
  unitPrice       Decimal @default(0) @db.Decimal(12, 2)
  discountPercent Decimal @default(0) @db.Decimal(5, 2)
  taxPercent      Decimal @default(0) @db.Decimal(5, 2)
  lineTotal       Decimal @default(0) @db.Decimal(12, 2)
  position        Int     @default(0)

  createdAt DateTime @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_items")
}

// ─────────────────────────────────────────────────────────────────────────
// CUSTOMER LOYALTY
// ─────────────────────────────────────────────────────────────────────────
model LoyaltyProgram {
  id        String @id @default(uuid())
  companyId String @unique

  name          String  @default("Loyalty Program")
  isActive      Boolean @default(true)
  pointsPerUnit Decimal @default(1) @db.Decimal(10, 4)
  currency      String  @default("TRY")
  minRedeem     Int     @default(0)
  redeemValue   Decimal @default(0.01) @db.Decimal(10, 4)

  tiers Json?
  rules Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]

  @@map("loyalty_programs")
}

model LoyaltyTransaction {
  id          String  @id @default(uuid())
  companyId   String
  customerId  String
  programId   String
  createdById String?

  points        Int
  type          String  @default("earn") // earn | redeem | adjust | expire
  reason        String?
  referenceType String?
  referenceId   String?

  createdAt DateTime @default(now())

  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer  Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  program   LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  createdBy User?          @relation("LoyaltyTxnCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([customerId])
  @@index([programId])
  @@index([type])
  @@index([createdAt])
  @@map("loyalty_transactions")
}

// ─────────────────────────────────────────────────────────────────────────
// TAX ENGINE
// ─────────────────────────────────────────────────────────────────────────
model TaxRate {
  id          String  @id @default(uuid())
  companyId   String

  name        String
  code        String?
  countryCode String?
  ratePercent Decimal @default(0) @db.Decimal(6, 3)
  isDefault   Boolean @default(false)
  isActive    Boolean @default(true)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([isActive])
  @@index([countryCode])
  @@map("tax_rates")
}

// ─────────────────────────────────────────────────────────────────────────
// SMART FOLLOW-UP SETTINGS
// ─────────────────────────────────────────────────────────────────────────
model FollowupSettings {
  id        String @id @default(uuid())
  companyId String @unique

  isEnabled       Boolean @default(true)
  warningDays     Int     @default(5)
  criticalDays    Int     @default(10)
  includeStatuses Json?
  excludeInactive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("followup_settings")
}

// ─────────────────────────────────────────────────────────────────────────
// COMMISSION ENGINE
// ─────────────────────────────────────────────────────────────────────────
model CommissionRule {
  id          String  @id @default(uuid())
  companyId   String

  name        String
  description String?
  type        String  @default("percent") // flat | percent | tiered
  config      Json    // { rate } for percent, { amount } for flat, { tiers: [{ from, to?, rate }] } for tiered
  appliesTo   String  @default("all") // all | deal_stage | min_value
  appliesToValue String?

  isActive Boolean @default(true)
  priority Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entries CommissionEntry[]

  @@index([companyId])
  @@index([isActive])
  @@index([priority])
  @@map("commission_rules")
}

model CommissionEntry {
  id        String @id @default(uuid())
  companyId String
  ruleId    String
  userId    String
  dealId    String

  baseValue Decimal @default(0) @db.Decimal(12, 2)
  rate      Decimal @default(0) @db.Decimal(8, 4)
  amount    Decimal @default(0) @db.Decimal(12, 2)
  currency  String  @default("TRY")

  status     String    @default("pending") // pending | approved | paid | cancelled
  approvedAt DateTime?
  paidAt     DateTime?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rule    CommissionRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal    Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, ruleId, userId])
  @@index([companyId])
  @@index([userId])
  @@index([dealId])
  @@index([ruleId])
  @@index([status])
  @@map("commission_entries")
}

// ─────────────────────────────────────────────────────────────────────────
// MARKETING CAMPAIGNS
// ─────────────────────────────────────────────────────────────────────────
model Campaign {
  id          String @id @default(uuid())
  companyId   String
  createdById String

  name    String
  subject String?
  channel String @default("email")  // email | whatsapp | sms
  status  String @default("draft")  // draft | scheduled | sending | sent | failed | cancelled

  bodyHtml  String?
  bodyText  String?
  fromName  String?
  fromEmail String?
  replyTo   String?

  targetType  String  @default("all") // all | status | tag | manual
  targetValue String?

  scheduledAt DateTime?
  sentAt      DateTime?

  recipientCount Int @default(0)
  sentCount      Int @default(0)
  deliveredCount Int @default(0)
  openedCount    Int @default(0)
  clickedCount   Int @default(0)
  bouncedCount   Int @default(0)
  failedCount    Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  User                @relation("CampaignCreator", fields: [createdById], references: [id])
  recipients CampaignRecipient[]

  @@index([companyId])
  @@index([status])
  @@index([channel])
  @@index([scheduledAt])
  @@map("campaigns")
}

model CampaignRecipient {
  id         String @id @default(uuid())
  campaignId String
  customerId String

  email String?
  phone String?

  status       String    @default("queued") // queued | sent | delivered | opened | clicked | bounced | failed
  sentAt       DateTime?
  deliveredAt  DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  errorMessage String?

  messageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([campaignId, customerId])
  @@index([campaignId])
  @@index([customerId])
  @@index([status])
  @@map("campaign_recipients")
}

// ─────────────────────────────────────────────────────────────────────────
// CONTRACT MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────
model Contract {
  id             String  @id @default(uuid())
  companyId      String
  customerId     String
  dealId         String?
  createdById    String

  contractNumber String
  title          String
  description    String?
  status         String  @default("draft") // draft | pending_signature | signed | active | expired | terminated

  startDate   DateTime?
  endDate     DateTime?
  renewalDate DateTime?
  signedAt    DateTime?

  value    Decimal @default(0) @db.Decimal(12, 2)
  currency String  @default("TRY")

  fileUrl  String?
  fileName String?
  notes    String?
  terms    String?

  reminderSent Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  createdBy User     @relation("ContractCreator", fields: [createdById], references: [id])

  @@unique([companyId, contractNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([dealId])
  @@index([status])
  @@index([endDate])
  @@index([renewalDate])
  @@map("contracts")
}

// ─────────────────────────────────────────────────────────────────────────
// CUSTOMER PORTAL — Magic-link tokens
// ─────────────────────────────────────────────────────────────────────────
model PortalToken {
  id         String @id @default(uuid())
  customerId String
  companyId  String

  token     String   @unique
  purpose   String   @default("login") // login | session
  expiresAt DateTime
  usedAt    DateTime?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([companyId])
  @@index([expiresAt])
  @@map("portal_tokens")
}

// ─────────────────────────────────────────────────────────────────────────
// INTERNAL CHAT — Direct messages between users
// ─────────────────────────────────────────────────────────────────────────
model ChatMessage {
  id         String @id @default(uuid())
  companyId  String
  fromUserId String
  toUserId   String

  content String
  readAt  DateTime?

  createdAt DateTime @default(now())

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromUser User    @relation("ChatSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User    @relation("ChatRecipient", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([createdAt])
  @@index([readAt])
  @@map("chat_messages")
}

// ─────────────────────────────────────────────────────────────────────────
// EXCHANGE RATES — Multi-currency conversion
// ─────────────────────────────────────────────────────────────────────────
model ExchangeRate {
  id        String @id @default(uuid())
  companyId String

  fromCurrency String
  toCurrency   String
  rate         Decimal @db.Decimal(14, 6)

  effectiveAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, fromCurrency, toCurrency])
  @@index([companyId])
  @@index([fromCurrency])
  @@index([toCurrency])
  @@map("exchange_rates")
}

// ─────────────────────────────────────────────────────────────────────────
// EMAIL TEMPLATES — reusable templates for campaigns
// ─────────────────────────────────────────────────────────────────────────
model EmailTemplate {
  id          String  @id @default(uuid())
  companyId   String
  createdById String

  name        String
  description String?
  category    String  @default("general")
  subject     String
  bodyHtml    String
  bodyText    String?

  variables   Json    @default("[]")
  isShared    Boolean @default(true)
  usageCount  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: NoAction)

  @@index([companyId])
  @@index([category])
  @@map("email_templates")
}

// ─────────────────────────────────────────────────────────────────────────
// CUSTOM FIELDS — company-defined fields for customers + deals
// ─────────────────────────────────────────────────────────────────────────
model CustomField {
  id           String  @id @default(uuid())
  companyId    String

  entityType   String
  fieldKey     String
  label        String
  fieldType    String  @default("text")
  options      Json?
  required     Boolean @default(false)
  defaultValue String?
  position     Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, entityType, fieldKey])
  @@index([companyId])
  @@index([entityType])
  @@map("custom_fields")
}

// ─────────────────────────────────────────────────────────────────────────
// ECOMMERCE STORE CONNECTIONS — generalized for 40+ platforms
// (Shopify, Salla, Zid, YouCan, Ticimax, ikas, Ideasoft, T-Soft, etc.)
// ─────────────────────────────────────────────────────────────────────────
model EcommerceStore {
  id          String  @id @default(uuid())
  companyId   String

  platform    String  @default("shopify")
  shopDomain  String
  accessToken String
  apiKey      String?
  apiSecret   String?
  region      String?
  currency    String?
  metadata    Json    @default("{}")

  isActive    Boolean @default(true)

  lastSyncAt              DateTime?
  syncStatus              String    @default("idle")
  syncError               String?
  totalCustomersImported  Int       @default(0)
  totalOrdersImported     Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, platform, shopDomain])
  @@index([companyId])
  @@index([platform])
  @@map("ecommerce_stores")
}

// ─────────────────────────────────────────────────────────────────────────
// WEBHOOKS — per-store inbound subscriptions + event log
// ─────────────────────────────────────────────────────────────────────────
model WebhookSubscription {
  id          String  @id @default(uuid())
  companyId   String
  storeId     String? // null = company-wide (rare); usually tied to an EcommerceStore
  platform    String  // shopify | salla | zid | woocommerce | youcan | ...
  topic       String  // customers/create, orders/updated, etc.
  secret      String  // HMAC signing secret; regenerable
  isActive    Boolean @default(true)

  // Operational stats
  lastReceivedAt DateTime?
  receivedCount  Int       @default(0)
  failedCount    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  events WebhookEvent[]

  @@unique([companyId, platform, storeId, topic])
  @@index([companyId])
  @@index([platform])
  @@index([storeId])
  @@map("webhook_subscriptions")
}

model WebhookEvent {
  id             String  @id @default(uuid())
  companyId      String
  subscriptionId String?
  platform       String
  topic          String
  externalId     String? // platform's event id (e.g. Shopify X-Shopify-Webhook-Id)

  // pending | processing | done | failed | skipped | dead_letter
  // failed       = last attempt errored, will retry at nextRetryAt
  // dead_letter  = exhausted retry budget, needs human intervention
  status    String @default("pending")
  attempts  Int    @default(0)
  lastError String?

  // When to make the next retry attempt. null for terminal states
  // (done/skipped/dead_letter) and in-flight events (pending/processing).
  nextRetryAt DateTime?

  payloadRaw  String  @db.Text         // raw body as received (for retries + forensics)
  payloadJson Json    @default("{}")

  // Verification telemetry
  signatureOk Boolean @default(true)
  receivedAt  DateTime @default(now())
  processedAt DateTime?

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription WebhookSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([platform, topic])
  @@index([status])
  @@index([receivedAt])
  @@index([status, nextRetryAt])
  @@map("webhook_events")
}
