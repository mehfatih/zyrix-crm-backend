# ============================================================================
# ZYRIX CRM BACKEND — Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in real values:
#     cp .env.example .env
# NEVER commit .env to Git.
# ============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000


# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────
# Railway: Copy from Railway Dashboard → PostgreSQL service → Connect
# Local: postgresql://user:password@localhost:5432/zyrix_crm
DATABASE_URL=postgresql://user:password@localhost:5432/zyrix_crm


# ─────────────────────────────────────────────────────────────────────────────
# REDIS (Optional — Phase 2 caching + queues)
# ─────────────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379


# ─────────────────────────────────────────────────────────────────────────────
# JWT SECRETS
# ─────────────────────────────────────────────────────────────────────────────
# Generate strong random strings (64+ chars) — use:
#     node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-strong-random-string-min-64-chars
JWT_REFRESH_SECRET=replace-with-another-strong-random-string-min-64-chars

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d


# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH
# ─────────────────────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${API_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret


# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (SMTP)
# ─────────────────────────────────────────────────────────────────────────────
# Options: Gmail, SendGrid, AWS SES, Postmark, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=Zyrix CRM <noreply@zyrix.co>


# ─────────────────────────────────────────────────────────────────────────────
# SMS (Optional — for 2FA via SMS)
# ─────────────────────────────────────────────────────────────────────────────
# Twilio: https://www.twilio.com/console
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=


# ─────────────────────────────────────────────────────────────────────────────
# AI — Google Gemini
# ─────────────────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key


# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100


# ─────────────────────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://crm.zyrix.co


# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info